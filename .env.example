# PostgreSQL
DATABASE_URL=postgres://transit_app:transit_dev_password@localhost:5432/transit?sslmode=disable

# Redis
REDIS_URL=localhost:6379
REDIS_PASSWORD=transit_dev_password

# JWT
JWT_SECRET=change_me_in_production
JWT_TTL_SECONDS=3600

# Driver Session
SESSION_TTL_SECONDS=60

# Geo / proximity
ARRIVAL_TOLERANCE_METERS=50

# Trip Planning
MAX_PLAN_RESULTS=3

# Buses active endpoint
BUSES_ACTIVE_DEFAULT_LIMIT=50
BUSES_ACTIVE_MAX_LIMIT=200

# Live ETA stream
LIVE_ETA_MAX_STREAM_MINUTES=45

# HTTP Server
PORT=8080
